{
  "name": "impact_historic",
  "version": "0.1.0",
  "description": "Axialent impact dashboard — historic survey data (Typeform + SurveyMonkey) + Next.js dashboard",
  "private": true,
  "scripts": {
    "extract": "bun run src/typeform/extract.ts",
    "extract:typeform": "bun run src/typeform/extract.ts",
    "extract:typeform:full": "bun run src/typeform/extract.ts --full",
    "normalize": "bun run src/normalize/normalize.ts",
    "refresh": "bun run extract && bun run normalize",
    "dev": "next dev",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
